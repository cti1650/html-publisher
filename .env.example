# GitHub Personal Access Token (required for persistent mode)
# Required scope: gist
# Generate at: https://github.com/settings/tokens
# If not set, all tools are stored in ephemeral cache
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Upstash Redis (required for ephemeral cache mode in production)
# If not set, in-memory fallback is used (data lost on restart, not safe on serverless)
# Create at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TTL for ephemeral cache entries in seconds (optional)
# Default: 21600 (6 hours). Sliding TTL — extended on every access.
CACHE_TTL_SECONDS=

# Secret for API Key generation (optional)
# If not set, authentication is skipped (for local development)
# Generate with: openssl rand -hex 32
SECRET=your-generated-secret

# API Key is dynamically generated from SECRET + GITHUB_TOKEN
# Generate with: npm run generate-api-key
# Or manually: echo -n "${SECRET}${GITHUB_TOKEN}" | shasum -a 256

# Slack Webhook URL for notifications (optional)
# If not set, notifications are skipped
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Base URL for tool links (optional)
# If not set, VERCEL_PROJECT_PRODUCTION_URL is used
# Example: https://example.com
BASE_URL=
